rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: leaderboards
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, < 50 chars) - Player's name
    //   - dots: integer (required, >= 0) - Data nodes collected
    //   - time: number (required, >= 0) - Survival time
    //   - date: string (required, ISO 8601 format) - Date achieved
    //   - mapIndex: integer (required, 0-2) - Map index
    //   - uid: string (required, matches auth.uid) - Player's UID
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidLeaderboardEntry(data) {
      return data.keys().hasAll(['name', 'dots', 'time', 'date', 'mapIndex', 'uid']) &&
             data.keys().hasOnly(['name', 'dots', 'time', 'date', 'mapIndex', 'uid']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             data.dots is int && data.dots >= 0 &&
             data.time is number && data.time >= 0 &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}.*") &&
             data.mapIndex is int && data.mapIndex >= 0 && data.mapIndex <= 2 &&
             data.uid is string && data.uid == request.auth.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "abdullamather0712@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /leaderboards/{entryId} {
      // Anyone can read the leaderboard
      allow read: if true;
      
      // Only authenticated users can create their own entries
      allow create: if isAuthenticated() && isValidLeaderboardEntry(request.resource.data);
      
      // Entries are immutable after creation
      allow update: if false;
      
      // Only admins can delete entries
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && request.resource.data.role == 'user';
      allow update: if isAuthenticated() && isOwner(userId) && request.resource.data.role == resource.data.role;
      allow delete: if isAdmin();
    }
  }
}
