rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: leaderboards
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, < 50 chars) - Player's name
    //   - dots: integer (required, >= 0) - Data nodes collected
    //   - time: number (required, >= 0) - Survival time
    //   - date: string (required, ISO 8601 format) - Date achieved
    //   - mapIndex: integer (required, 0-5) - Map index
    //   - uid: string (required) - Firebase Auth UID
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "abdullamather0712@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidLeaderboardEntry(data) {
      return data.keys().hasAll(['name', 'dots', 'time', 'date', 'mapIndex', 'uid', 'mode']) &&
             data.keys().hasOnly(['name', 'dots', 'time', 'date', 'mapIndex', 'uid', 'mode']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             data.dots is number && data.dots >= 0 &&
             data.time is number && data.time >= 0 &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}.*") &&
             data.mapIndex is number && data.mapIndex >= 0 &&
             data.mode is string && data.mode in ['NORMAL', 'CHANGING_MAZE', 'HARD'] &&
             data.uid is string && data.uid == request.auth.uid;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /leaderboards/{entryId} {
      // Anyone can read the leaderboard
      allow read: if true;
      
      // Only authenticated users can create or update their own entries
      allow create: if isAuthenticated() && isValidLeaderboardEntry(request.resource.data);
      allow update: if isAuthenticated() && 
                      isOwner(resource.data.uid) && 
                      isValidLeaderboardEntry(request.resource.data) &&
                      (request.resource.data.dots > resource.data.dots || 
                       (request.resource.data.dots == resource.data.dots && request.resource.data.time > resource.data.time));
      
      // No one can delete entries via client
      allow delete: if false;
    }

    match /leaderboard_emails/{entryId} {
      // Only the owner or the admin can read the email
      allow read: if isAuthenticated() && (isOwner(resource.data.uid) || isAdmin());
      
      // Only authenticated users can create or update their own email entry
      allow create: if isAuthenticated() && 
                      request.resource.data.uid == request.auth.uid &&
                      request.resource.data.email == request.auth.token.email;
      allow update: if isAuthenticated() && 
                      isOwner(resource.data.uid) && 
                      request.resource.data.email == request.auth.token.email;
      
      // No one can delete emails via client
      allow delete: if false;
    }

    match /lobbies/{lobbyId} {
      // Anyone authenticated can list lobbies to join
      allow read: if isAuthenticated();
      
      // Anyone authenticated can create a lobby
      allow create: if isAuthenticated() && 
                      request.resource.data.hostUid == request.auth.uid;
      
      // Only participants can update the lobby state
      allow update: if isAuthenticated() && (
        // Host can update
        request.auth.uid == resource.data.hostUid || 
        // Existing guest can update
        (resource.data.get('guestUid', null) != null && request.auth.uid == resource.data.guestUid) || 
        // New guest can join if no guest exists and they are setting themselves as guest
        (resource.data.get('guestUid', null) == null && request.resource.data.guestUid == request.auth.uid)
      );
      
      // Only the host can delete the lobby
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.hostUid;
    }
  }
}
