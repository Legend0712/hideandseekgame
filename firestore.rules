rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: leaderboards
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, < 50 chars) - Player's name
    //   - dots: integer (required, >= 0) - Data nodes collected
    //   - time: number (required, >= 0) - Survival time
    //   - date: string (required, ISO 8601 format) - Date achieved
    //   - mapIndex: integer (required, 0-5) - Map index
    //   - uid: string (required) - Firebase Auth UID
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidLeaderboardEntry(data) {
      return data.keys().hasAll(['name', 'dots', 'time', 'date', 'mapIndex', 'uid']) &&
             data.keys().hasOnly(['name', 'dots', 'time', 'date', 'mapIndex', 'uid']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             data.dots is int && data.dots >= 0 &&
             data.time is number && data.time >= 0 &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}.*") &&
             data.mapIndex is int && data.mapIndex >= 0 && data.mapIndex <= 5 &&
             data.uid is string && data.uid == request.auth.uid;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /leaderboards/{entryId} {
      // Anyone can read the leaderboard
      allow read: if true;
      
      // Only authenticated users can create or update their own entries
      allow create: if isAuthenticated() && isValidLeaderboardEntry(request.resource.data);
      allow update: if isAuthenticated() && 
                      isOwner(resource.data.uid) && 
                      isValidLeaderboardEntry(request.resource.data) &&
                      (request.resource.data.dots > resource.data.dots || 
                       (request.resource.data.dots == resource.data.dots && request.resource.data.time > resource.data.time));
      
      // No one can delete entries via client
      allow delete: if false;
    }
  }
}
