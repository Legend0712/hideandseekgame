{
  "entities": {
    "LeaderboardEntry": {
      "title": "Leaderboard Entry",
      "description": "A single best score entry for a specific user on a specific map",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The player's name"
        },
        "dots": {
          "type": "integer",
          "description": "Number of data nodes collected"
        },
        "time": {
          "type": "number",
          "description": "Survival time in seconds"
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "The date the score was achieved"
        },
        "mapIndex": {
          "type": "integer",
          "description": "The index of the map"
        },
        "uid": {
          "type": "string",
          "description": "The unique ID of the player (Firebase Auth UID)"
        }
      },
      "required": ["name", "dots", "time", "date", "mapIndex", "uid"]
    },
    "Lobby": {
      "title": "Multiplayer Lobby",
      "description": "A session for a 2-player multiplayer game",
      "type": "object",
      "properties": {
        "hostUid": { "type": "string" },
        "hostName": { "type": "string" },
        "guestUid": { "type": "string" },
        "guestName": { "type": "string" },
        "status": { "type": "string", "enum": ["WAITING", "PLAYING", "FINISHED"] },
        "mapIndex": { "type": "integer" },
        "player1Pos": { "type": "object" },
        "player2Pos": { "type": "object" },
        "player1Dots": { "type": "integer" },
        "player2Dots": { "type": "integer" },
        "player1Status": { "type": "string", "enum": ["ALIVE", "CAUGHT"] },
        "player2Status": { "type": "string", "enum": ["ALIVE", "CAUGHT"] },
        "winner": { "type": "string" },
        "lastUpdate": { "type": "number" }
      },
      "required": ["hostUid", "hostName", "status", "mapIndex", "lastUpdate"]
    }
  },
  "firestore": {
    "/leaderboards/{entryId}": {
      "schema": "LeaderboardEntry",
      "description": "Global leaderboard entries for all maps"
    },
    "/leaderboard_emails/{entryId}": {
      "schema": "object",
      "description": "Private emails for leaderboard entries, only readable by admin"
    },
    "/lobbies/{lobbyId}": {
      "schema": "Lobby",
      "description": "Active and finished multiplayer lobbies"
    }
  }
}
